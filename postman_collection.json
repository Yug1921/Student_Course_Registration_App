            "url": {
              "raw": "{{baseUrl}}/api/enrollments/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "enrollments", ":id"],
              "variable": [{ "key": "id", "value": "REPLACE_WITH_ENROLLMENT_ID" }]
            }
          },
          "response": []
