      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Process Payment (Success)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () { pm.response.to.have.status(201); });",
                  "const json = pm.response.json();",
                  "pm.test('Status is success', function () { pm.expect(json.status).to.equal('success'); });",
                  "pm.test('Has transactionId', function () { pm.expect(json.transactionId).to.be.a('string'); });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 150,\n  \"description\": \"Spring semester registration fee\",\n  \"cardNumber\": \"4111111111111111\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/payments/process",
              "host": ["{{baseUrl}}"],
              "path": ["api", "payments", "process"]
            }
          },
          "response": []
