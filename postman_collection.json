            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 150,\n  \"description\": \"Spring semester registration fee\",\n  \"cardNumber\": \"0000111122223333\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/payments/process",
              "host": ["{{baseUrl}}"],
              "path": ["api", "payments", "process"]
            }
          },
          "response": []
